---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Submit Changes | SDN"
  description="Submit website change requests"
  canonicalPath="/change/"
>
  <section class="page-hero">
    <h1>Submit a change request</h1>
    <p>Use the form below to request updates to website content.</p>
  </section>

  <section class="form-section">
    <div class="container">
      <iframe
        src="https://docs.google.com/forms/d/e/1FAIpQLSdABn5tKaAb1UZ23kPr9bGr5te5ZRAKxR3aBYA2wt2XHe-mNg/viewform?embedded=true"
        width="100%"
        height="800"
        frameborder="0"
        marginheight="0"
        marginwidth="0">
        Loading...
      </iframe>
    </div>
  </section>
</BaseLayout>

<style>
  .form-section {
    padding: 3rem 1.5rem 5rem;
  }
  .container {
    max-width: 800px;
    margin: 0 auto;
  }
  iframe {
    border: none;
    border-radius: 8px;
  }
</style>
