---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Arena & Golf Course Advertising Partnership",
  "provider": {
    "@type": "Organization",
    "name": "Sports Digital Network"
  },
  "description": "Turn your arena or golf course into a revenue stream. SDN installs screens, sells ads, and pays you monthly. Zero cost, zero effort.",
  "areaServed": {
    "@type": "Country",
    "name": "Canada"
  },
  "serviceType": "Venue Advertising Partnership"
};
---

<BaseLayout
  title="Arena & Golf Course Advertising Partnership | Earn Revenue with SDN"
  description="Turn your arena or golf course into a revenue stream. SDN installs screens, sells ads, and pays you monthly. Zero cost, zero effort. Apply to join our network."
  canonicalPath="/venues/"
  schema={serviceSchema}
>
  <section class="page-hero">
    <h1>Turn your venue's foot traffic into monthly revenue</h1>
    <p>We purchase each screen. We install the screens. We sell the ads. You get paid.</p>
  </section>

  <section class="intro-section">
    <div class="container">
      <p class="lead">Your arena, recreation centre, or golf course sees thousands of visitors every week. SDN turns that foot traffic into a new revenue stream — without costing you a dollar or a minute of your staff's time.</p>
      <p>We purchase and install commercial-grade digital screens in your facility, sell the advertising, manage the content, and deliver revenue to you. Your visitors receive sports content, weather updates, and community information on professional displays. Your facility looks more modern. And you don't have to do anything.</p>
      <p><strong>Over 100 venues across Canada already partner with SDN.</strong></p>
    </div>
  </section>

  <section class="how-section">
    <div class="container">
      <h2>How the partnership works</h2>

      <div class="how-grid">
        <div class="how-card">
          <h3>We invest. You earn.</h3>
          <p><strong>SDN covers 100% of the cost.</strong> We purchase the screens, pay for installation, handle ongoing maintenance, and manage all content and advertising sales. Your facility pays nothing — ever.</p>
        </div>
        <div class="how-card">
          <h3>Revenue-sharing</h3>
          <p>You receive a payment based on our revenue-sharing agreement. The amount depends on your venue's size, visitor traffic, and market.</p>
        </div>
        <div class="how-card">
          <h3>Your staff does nothing</h3>
          <p>Our screens are connected to our network and managed remotely. Content updates, ad scheduling, troubleshooting — it's all handled by our team. If a screen ever needs physical service, we send our own technicians.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <h2>What your facility gets</h2>

      <div class="benefits-grid">
        <div class="benefit-card">
          <h3>Revenue</h3>
          <p>A new, passive income stream with zero upfront investment and zero ongoing cost. For multi-pad arenas and busy golf courses, the annual revenue is meaningful — often comparable to a significant sponsorship deal, but with no sales effort on your part.</p>
        </div>
        <div class="benefit-card">
          <h3>Modern facility upgrades</h3>
          <p>Professional 65" – 86" 4K displays replace outdated bulletin boards and static signage. Visitors and user groups notice the difference immediately. Several of our partner facilities have cited the screens as a factor in improved user satisfaction scores.</p>
        </div>
        <div class="benefit-card">
          <h3>Useful content for visitors</h3>
          <p>Our screens aren't just advertising. They display real-time information that visitors actually want — weather, sports scores, and community event listings. This makes the screens a functional addition to your facility.</p>
        </div>
        <div class="benefit-card">
          <h3>National advertising demand</h3>
          <p>SDN's relationships with national brands and media agencies mean your facility gets access to advertising demand you could never generate on your own. National campaigns from major brands run on your screens alongside local business advertising.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="partners-section">
    <div class="container">
      <h2>Who we partner with</h2>

      <div class="partner-types">
        <div class="partner-card">
          <h3>Community arenas</h3>
          <p>Multi-pad hockey arenas and recreation centres are our core venue type. If your facility has 2+ ice pads and serves as a community hub, you're an ideal SDN partner.</p>
          <a href="/contact/" class="partner-cta">Become a partner</a>
        </div>

        <div class="partner-card">
          <h3>Golf courses</h3>
          <p>Private and resort golf courses offer a premium audience environment for our advertisers. ClubLink — Canada's largest owner of private golf courses — is an SDN partner, with screens in 26 Ontario clubhouses.</p>
          <p class="partner-note">We're expanding our golf network and looking for new course partners.</p>
          <a href="/contact/" class="partner-cta">Become a partner</a>
        </div>

        <div class="partner-card">
          <h3>Indoor soccer and multi-sport facilities</h3>
          <p>Large indoor sports facilities with high foot traffic are excellent SDN venues. We operate screens in many of Canada's largest indoor soccer complexes and multi-sport centres.</p>
          <a href="/contact/" class="partner-cta">Become a partner</a>
        </div>
      </div>
    </div>
  </section>

  <section class="comparison-section">
    <div class="container">
      <h2>What makes SDN different from other arena advertising companies</h2>
      <p>Most arena advertising companies ask you to sell the ad space, manage the relationships, and handle the logistics. SDN is different:</p>

      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Traditional arena ad company</th>
              <th>SDN</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Who pays for signage?</strong></td>
              <td>You buy the boards</td>
              <td>SDN pays for everything</td>
            </tr>
            <tr>
              <td><strong>Who sells the ads?</strong></td>
              <td>You or a local rep</td>
              <td>SDN's national sales team</td>
            </tr>
            <tr>
              <td><strong>Who manages content?</strong></td>
              <td>You or your staff</td>
              <td>SDN manages remotely</td>
            </tr>
            <tr>
              <td><strong>Revenue model</strong></td>
              <td>You keep ad revenue minus costs</td>
              <td>Consistent revenue stream</td>
            </tr>
            <tr>
              <td><strong>Advertiser access</strong></td>
              <td>Local businesses only</td>
              <td>National brands + local businesses</td>
            </tr>
            <tr>
              <td><strong>Technology</strong></td>
              <td>Static boards and banners</td>
              <td>Digital 4K screens, programmatic-ready</td>
            </tr>
            <tr>
              <td><strong>Maintenance</strong></td>
              <td>Your responsibility</td>
              <td>SDN handles all service</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      <h2>See our screens in action</h2>
      <p class="gallery-intro">Our 65-inch 4K displays are installed in high-traffic areas throughout our partner venues.</p>
      <div class="photo-grid">
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-01.jpg" alt="SDN digital screen in arena lobby" loading="lazy" />
        </div>
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-02.jpg" alt="Digital advertising display near rink entrance" loading="lazy" />
        </div>
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-03.jpg" alt="Arena hallway screen installation" loading="lazy" />
        </div>
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-04.jpg" alt="SDN screen showing sponsor advertisement" loading="lazy" />
        </div>
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-05.jpg" alt="Digital display in arena common area" loading="lazy" />
        </div>
        <div class="photo-card">
          <img src="/images/arenas/arena-screen-06.jpg" alt="Screen placement near rink scheduling board" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Apply to join the SDN network</h2>
    <p>If your arena, golf course, or recreation facility is in a Canadian market with strong visitor traffic, we'd like to talk. Complete our partner application and we'll respond within two business days with a preliminary revenue estimate.</p>
    <a href="/contact/" class="btn-white">Become a partner</a>
  </section>
</BaseLayout>

<style>
  .intro-section {
    padding: 4rem 1.5rem;
    background: var(--gray-100);
  }
  .container {
    max-width: 1140px;
    margin: 0 auto;
  }
  .lead {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .intro-section p {
    color: var(--gray-600, #495057);
    font-size: 1.1rem;
    max-width: 900px;
    margin-bottom: 1rem;
  }

  .how-section {
    padding: 5rem 1.5rem;
  }
  .how-section h2 {
    text-align: center;
    margin-bottom: 3rem;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .how-card {
    padding: 2rem;
    background: var(--gray-100);
    border-radius: 8px;
  }
  .how-card h3 {
    margin-bottom: 1rem;
  }
  .how-card p {
    color: var(--gray-500);
    margin: 0;
  }

  .benefits-section {
    padding: 5rem 1.5rem;
    background: var(--gray-100);
  }
  .benefits-section h2 {
    text-align: center;
    margin-bottom: 3rem;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .benefit-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 8px;
  }
  .benefit-card h3 {
    margin-bottom: 1rem;
  }
  .benefit-card p {
    color: var(--gray-500);
    margin: 0;
  }

  .partners-section {
    padding: 5rem 1.5rem;
  }
  .partners-section h2 {
    text-align: center;
    margin-bottom: 3rem;
  }
  .partner-types {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .partner-card {
    background: var(--gray-100);
    padding: 2rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: box-shadow 0.3s ease;
  }
  a.partner-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .partner-card h3 {
    margin-bottom: 1rem;
  }
  .partner-card p {
    color: var(--gray-500);
    margin-bottom: 1rem;
  }
  .partner-note {
    font-size: 0.9rem;
    font-style: italic;
  }
  .partner-cta {
    display: inline-block;
    margin-top: 1rem;
    color: var(--blue);
    font-weight: 600;
    text-decoration: none;
  }
  .partner-cta:hover {
    text-decoration: underline;
  }

  .comparison-section {
    padding: 5rem 1.5rem;
    background: var(--gray-100);
  }
  .comparison-section h2 {
    margin-bottom: 1rem;
  }
  .comparison-section > .container > p {
    color: var(--gray-500);
    margin-bottom: 2rem;
  }
  .comparison-table {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
  }
  th, td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--gray-200, #e9ecef);
  }
  th {
    background: var(--black);
    color: var(--white);
    font-weight: 600;
  }
  th:first-child {
    background: var(--gray-100);
    color: var(--black);
  }
  td:first-child {
    background: var(--gray-100);
  }

  .gallery-section {
    padding: 5rem 1.5rem;
    background: var(--gray-100);
  }
  .gallery-section h2 {
    text-align: center;
    margin-bottom: 1rem;
  }
  .gallery-intro {
    text-align: center;
    color: var(--gray-500);
    margin-bottom: 2.5rem;
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .photo-card {
    border-radius: 8px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .photo-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .how-grid {
      grid-template-columns: 1fr;
    }
    .partner-types {
      grid-template-columns: 1fr;
    }
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    .faq-grid {
      grid-template-columns: 1fr;
    }
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
