---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does arena advertising cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rates vary by market size, number of venues, campaign duration, and format. Contact us for a quote."
      }
    },
    {
      "@type": "Question",
      "name": "What creative specs do you accept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Static images (1920x1080 px, JPG/PNG) and video (MP4, up to 15 seconds, 1080p). Our design team can produce creative at no extra charge."
      }
    },
    {
      "@type": "Question",
      "name": "What does it cost to join the SDN network?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nothing. SDN covers all costs — screens, installation, maintenance, content management, and advertising sales. Your facility pays nothing, ever."
      }
    }
  ]
};
---

<BaseLayout
  title="Frequently Asked Questions | Arena Advertising | SDN"
  description="Common questions about arena and venue advertising with Sports Digital Network. Learn about costs, creative specs, campaign length, targeting, and measurement."
  canonicalPath="/faqs/"
  schema={faqSchema}
>
  <section class="page-hero">
    <h1>Frequently asked questions</h1>
    <p>Everything you need to know about advertising with Sports Digital Network.</p>
  </section>

  <!-- Advertiser FAQs -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Frequently asked questions by advertisers</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>How much does arena advertising cost?</h3>
          <p>Rates vary by market size, number of venues, campaign duration, and format. <a href="/contact/">Contact us for a quote</a>.</p>
        </div>
        <div class="faq-item">
          <h3>How much does it cost to advertise at a single arena?</h3>
          <p>Local single-venue campaigns are our most affordable option, designed for small business budgets. Rates depend on the specific venue and your campaign length. Longer commitments get better rates. <a href="/contact/">Contact us for a quote</a>.</p>
        </div>
        <div class="faq-item">
          <h3>What creative specs do you accept?</h3>
          <p>Static images (1920x1080 px, JPG/PNG) and video (MP4, up to 15 seconds, 1080p). Our design team can produce creative at no extra charge.</p>
        </div>
        <div class="faq-item">
          <h3>How long is a typical campaign?</h3>
          <p>Campaigns run in 4-week increments with a minimum 4-week commitment. Longer flights receive preferred rates.</p>
        </div>
        <div class="faq-item">
          <h3>Can I target specific venues?</h3>
          <p>Yes. Select individual venues, groups of venues in a market, or activate across the entire national network.</p>
        </div>
        <div class="faq-item">
          <h3>How is arena advertising measured?</h3>
          <p>We report impressions based on verified venue foot traffic data. All screens provide proof-of-play confirmation.</p>
        </div>
        <div class="faq-item">
          <h3>Can I advertise at multiple venues?</h3>
          <p>Absolutely. Many local businesses advertise at 2-5 nearby venues to cover their entire service area, while provincial associations cluster venues based on province, and national brands across Canada. We are scalable.</p>
        </div>
        <div class="faq-item">
          <h3>Can I buy programmatically?</h3>
          <p>Yes. We're integrated with Broadsign and available through major DSPs. Contact us for Deal IDs.</p>
        </div>
        <div class="faq-item">
          <h3>Do I need to provide my own ad design?</h3>
          <p>No. Our design team creates your ad at no extra charge. Just send us your logo and the message you want to communicate.</p>
        </div>
        <div class="faq-item">
          <h3>How long should I run my campaign?</h3>
          <p>We recommend a minimum of 12 weeks. Venue advertising builds recognition through repetition — the same families see your ad week after week. The longer you run, the stronger the recall.</p>
        </div>
        <div class="faq-item">
          <h3>What if I want to change my ad?</h3>
          <p>You can update your creative at any time during your campaign. Seasonal promotions, new offers, or refreshed messaging — just send us the update and we'll have it live within 48 hours.</p>
        </div>
        <div class="faq-item">
          <h3>Is this better than sponsoring a local team?</h3>
          <p>Team sponsorship gets your name on a jersey seen by one team's parents. Venue advertising puts your message in front of every person who walks into the building — across every sport, every age group, and every event. The reach is dramatically larger.</p>
        </div>
      </div>

      <div class="cta-box">
        <h3>Put your brand in the game</h3>
        <p>Request a custom proposal for your campaign. Our team will respond within one business day.</p>
        <div class="cta-buttons">
          <a href="/contact/" class="btn btn-primary">Request a proposal</a>
          <a href="/resources/" class="btn btn-secondary">Download our media kit</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Facility Owner FAQs -->
  <section class="faq-section faq-section-alt">
    <div class="container">
      <h2 class="section-title">Frequently asked questions by venue owners</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>What does it cost to join the SDN network?</h3>
          <p>Nothing. SDN covers all costs — screens, installation, maintenance, content management, and advertising sales. Your facility pays nothing, ever.</p>
        </div>
        <div class="faq-item">
          <h3>How much revenue can I expect?</h3>
          <p>Revenue depends on your venue's size, visitor traffic, and market. We'll provide a detailed revenue estimate as part of our partnership proposal.</p>
        </div>
        <div class="faq-item">
          <h3>How long is the partnership agreement?</h3>
          <p>Typical agreements are multi-year, which allows us to invest in your facility with confidence. We'll discuss term options during the proposal process.</p>
        </div>
        <div class="faq-item">
          <h3>What do the screens look like?</h3>
          <p>We install 65" – 86" commercial-grade 4K displays in professional wall mounts. Placement is determined collaboratively — we identify high-traffic locations and work with your team on final positioning.</p>
        </div>
        <div class="faq-item">
          <h3>Will this conflict with existing sponsorships?</h3>
          <p>We work around your existing commitments. If you have current sponsors with category exclusivity, we honour those agreements and build our ad sales around them.</p>
        </div>
        <div class="faq-item">
          <h3>Do I need to provide internet connectivity?</h3>
          <p>Yes. Each screen requires a wired internet connection. If connectivity isn't available in the installation location, we'll work with you to find a solution.</p>
        </div>
        <div class="faq-item">
          <h3>What happens if a screen breaks?</h3>
          <p>SDN handles all maintenance and replacement at our cost. We monitor screens remotely and dispatch service when needed.</p>
        </div>
      </div>

      <div class="cta-box cta-box-dark">
        <h3>Make your facility a place advertisers and brands can connect with their community</h3>
        <a href="/contact/" class="btn btn-white">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-section {
    padding: 4rem 1.5rem;
  }
  .faq-section-alt {
    background: var(--gray-100);
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
  }
  .section-title {
    font-size: 1.75rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--blue);
  }
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .faq-item {
    background: var(--white);
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 3px solid var(--blue);
  }
  .faq-section-alt .faq-item {
    background: var(--white);
  }
  .faq-item h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--black);
  }
  .faq-item p {
    color: var(--gray-500);
    margin: 0;
    line-height: 1.7;
  }
  .faq-item a {
    color: var(--blue);
  }

  .cta-box {
    background: var(--gray-100);
    padding: 2.5rem;
    border-radius: 8px;
    text-align: center;
  }
  .cta-box-dark {
    background: var(--black);
    color: var(--white);
  }
  .cta-box h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  .cta-box p {
    color: var(--gray-500);
    margin-bottom: 1.5rem;
  }
  .cta-box-dark p {
    color: rgba(255,255,255,0.8);
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-primary {
    background: var(--blue);
    color: var(--white);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
  }
  .btn-secondary {
    background: var(--white);
    color: var(--black);
    border: 2px solid var(--gray-300);
  }
  .btn-secondary:hover {
    border-color: var(--blue);
  }
  .btn-white {
    background: var(--white);
    color: var(--blue);
  }
  .btn-white:hover {
    transform: translateY(-2px);
  }

  .quote-section {
    padding: 5rem 1.5rem;
    text-align: center;
    background: linear-gradient(135deg, var(--blue) 0%, #1a4a7a 100%);
    color: var(--white);
  }
  .quote-section h2 {
    margin-bottom: 1rem;
  }
  .quote-section p {
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .quote-section .btn-primary {
    background: var(--white);
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
